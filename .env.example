# ─────────────────────────────────────────────────────────────────────────────
# Ember — environment variables
# Copy this file to .env and fill in any OPTIONAL vars you need.
# The defaults below work for local Docker dev with no changes.
#
#   cp .env.example .env
#   docker compose up --build
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# These three values must stay in sync.
# ANON_KEY and SERVICE_ROLE_KEY are pre-computed JWTs for JWT_SECRET below.
# To rotate: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7ACcEgnkANMDw9c3cCKVzPOB5BWBBBPH3Q
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl296z-CPCGo

# Required by Realtime service (random 64-char hex)
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq

# Required by Studio + postgres-meta (random 32-char string)
PG_META_CRYPTO_KEY=d3a2f8c1e9b4071562934ad8fc0e7b25

# Studio dashboard credentials (for the Kong admin panel)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin

# ── URLs ──────────────────────────────────────────────────────────────────────
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:54321
ADDITIONAL_REDIRECT_URLS=

# ── OPTIONAL: Stripe (payments) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── OPTIONAL: other services ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=       # AI prompt personalisation  → console.anthropic.com
POSTHOG_KEY=             # Analytics                  → posthog.com
SENTRY_DSN=              # Error tracking             → sentry.io
RESEND_API_KEY=          # Transactional email        → resend.com
REVENUECAT_SECRET=       # Mobile subscriptions       → revenuecat.com
REVENUECAT_WEBHOOK_AUTH= # RevenueCat webhook secret
EXPO_ACCESS_TOKEN=       # EAS / Expo builds          → expo.dev
